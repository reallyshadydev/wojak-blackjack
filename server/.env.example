# ── WojakCoin Blackjack — house server configuration ───────────────────────
# Copy to `server/.env` and edit. All values are optional; sane defaults shown.

# HTTP port for the house API.
PORT=8787

# Chain: mainnet | testnet
NETWORK=mainnet

# DEMO_MODE (default true): no real transactions are broadcast and no funds
# move. Deposits/withdrawals are simulated and new players get a free balance,
# so the game is fully playable and verifiable out of the box.
#
# Set to false to settle REAL WojakCoin on-chain:
#   1. npm run generate-wallet
#   2. Fund the printed house address with WJK
#   3. DEMO_MODE=false
DEMO_MODE=true

# electrs (esplora) REST API + block explorer.
API_URL=https://api.wojakcoin.cash
EXPLORER_URL=https://explorer.wojakcoin.cash
# ord index — used to avoid spending inscription-bearing UTXOs.
ORD_URL=https://ord.wojakcoin.cash

# House payout fee rate (sats/byte).
FEE_RATE=50

# Bet limits (in satoshis; 1 WJK = 100,000,000 sats).
MIN_BET_SATS=5000000
MAX_BET_SATS=2500000000

# Provably-fair: number of hands committed by a single on-chain anchor before a
# new anchor transaction is written. One on-chain tx covers this many hands.
EPOCH_LENGTH=256

# DEMO_MODE-only knobs.
DEMO_BANKROLL_SATS=10000000000000
DEMO_WELCOME_SATS=10000000000

# Blackjack rules (same engine runs server-side and in the in-browser verifier).
# Tweaking these changes house edge but not provable fairness — the deck is still
# deterministic from the committed seeds; payouts follow these published rules.
DEALER_HITS_SOFT17=false
BLACKJACK_PAYS=1.5
MAX_SPLITS=3
DOUBLE_AFTER_SPLIT=true
ONE_CARD_AFTER_SPLIT_ACE=true
NO_RESPLIT_ACES=true
INSURANCE_OFFERED=true
INSURANCE_PAYS=2

# Require a wallet message-signature to authorize withdrawals (live mode).
REQUIRE_WITHDRAW_SIG=false

# CORS origin for the web app (use the deployed origin in production).
CORS_ORIGIN=*
